<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="apriltag_board">
    <static>true</static>

    <link name="link">
      <collision name="collision">
        <geometry>
          <box>
            <size>0.01 0.40 0.40</size>
          </box>
        </geometry>
      </collision>

      <!-- 앞면 -->
      <visual name="front_visual">
        <pose>0 0 0 0 1.57079632679 0</pose>
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>0.40 0.40</size>
          </plane>
        </geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <emissive>1 1 1 1</emissive>
          <pbr>
            <metal>
              <albedo_map>materials/textures/tag.png</albedo_map>
              <metalness>0.0</metalness>
              <roughness>1.0</roughness>
            </metal>
          </pbr>
        </material>
      </visual>

      <!-- 뒷면 -->
      <visual name="back_visual">
        <pose>0 0 0 0 -1.57079632679 0</pose>
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>0.40 0.40</size>
          </plane>
        </geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <emissive>1 1 1 1</emissive>
          <pbr>
            <metal>
              <albedo_map>materials/textures/tag.png</albedo_map>
              <metalness>0.0</metalness>
              <roughness>1.0</roughness>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>
</sdf>
