"""
jackal-ORCA bringup_all.launch.py
- RealSense D435i 카메라 2대
- Livox Mid-360 (sensor_msgs/PointCloud2)
- 정적 TF + RViz2
"""

import os
from launch import LaunchDescription
from launch.actions import IncludeLaunchDescription, TimerAction, LogInfo
from launch.launch_description_sources import PythonLaunchDescriptionSource
from launch_ros.actions import Node
from ament_index_python.packages import get_package_share_directory

CAM1_SERIAL = "344522070202"
CAM2_SERIAL = "344522070059"
CAM_PROFILE = "640x480x30"

RVIZ_CONFIG = os.path.join(
    os.path.dirname(os.path.abspath(__file__)),
    'bringup_all.rviz'
)


def generate_launch_description():
    rs_launch_file = os.path.join(
        get_package_share_directory('realsense2_camera'),
        'launch', 'rs_launch.py',
    )

    livox_share = get_package_share_directory('livox_ros_driver2')
    livox_config = os.path.join(livox_share, 'config', 'MID360_config.json')

    common_cam_args = {
        'enable_color': 'true',
        'enable_depth': 'true',
        'enable_infra1': 'false',
        'enable_infra2': 'false',
        'pointcloud.enable': 'true',
        'align_depth.enable': 'true',
        'depth_module.profile': CAM_PROFILE,
        'rgb_camera.profile': CAM_PROFILE,
        'initial_reset': 'true',
        'enable_sync': 'true',
    }

    cam1 = IncludeLaunchDescription(
        PythonLaunchDescriptionSource(rs_launch_file),
        launch_arguments={
            **common_cam_args,
            'serial_no': f"'{CAM1_SERIAL}'",
            'camera_name': 'camera1',
            'camera_namespace': '',
        }.items(),
    )

    cam2 = IncludeLaunchDescription(
        PythonLaunchDescriptionSource(rs_launch_file),
        launch_arguments={
            **common_cam_args,
            'serial_no': f"'{CAM2_SERIAL}'",
            'camera_name': 'camera2',
            'camera_namespace': '',
        }.items(),
    )

    livox = Node(
        package='livox_ros_driver2',
        executable='livox_ros_driver2_node',
        name='livox_lidar_publisher',
        output='screen',
        parameters=[
            {'xfer_format': 0},
            {'multi_topic': 0},
            {'data_src': 0},
            {'publish_freq': 10.0},
            {'output_data_type': 0},
            {'frame_id': 'livox_frame'},
            {'lvx_file_path': '/home/livox/livox_test.lvx'},
            {'user_config_path': livox_config},
            {'cmdline_input_bd_code': 'livox0000000001'},
        ],
    )

    tf_base_to_livox = Node(
        package='tf2_ros', executable='static_transform_publisher',
        name='base_to_livox',
        arguments=['0', '0', '0.3', '0', '0', '0', 'base_link', 'livox_frame'],
    )
    tf_base_to_cam1 = Node(
        package='tf2_ros', executable='static_transform_publisher',
        name='base_to_cam1',
        arguments=['0.2', '0.1', '0.2', '0', '0', '0', 'base_link', 'camera1_link'],
    )
    tf_base_to_cam2 = Node(
        package='tf2_ros', executable='static_transform_publisher',
        name='base_to_cam2',
        arguments=['0.2', '-0.1', '0.2', '0', '0', '0', 'base_link', 'camera2_link'],
    )

    rviz_args = ['-d', RVIZ_CONFIG] if os.path.exists(RVIZ_CONFIG) else []
    rviz = TimerAction(
        period=3.0,
        actions=[Node(
            package='rviz2', executable='rviz2', name='rviz2',
            arguments=rviz_args, output='screen',
        )],
    )

    return LaunchDescription([
        LogInfo(msg=f"[bringup_all] CAM1={CAM1_SERIAL}, CAM2={CAM2_SERIAL}"),
        LogInfo(msg=f"[bringup_all] Livox config: {livox_config}"),
        LogInfo(msg=f"[bringup_all] RViz config: {RVIZ_CONFIG}"),
        cam1, cam2, livox,
        tf_base_to_livox, tf_base_to_cam1, tf_base_to_cam2,
        rviz,
    ])
